# ===========================================
# Finance APP - Environment Configuration
# ===========================================
# Copy this file to .env and fill in values:
#   cp .env.example .env

# --- PostgreSQL ---
POSTGRES_DB=finance_app
POSTGRES_USER=finance
POSTGRES_PASSWORD=change_me_in_production

# --- Database URL (used by backend) ---
DATABASE_URL=postgresql+asyncpg://finance:change_me_in_production@db:5432/finance_app

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Ollama ---
OLLAMA_HOST=http://ollama:11434

# --- Environment ---
# Set to "production" for live deployments (enforces SECRET_KEY validation)
ENVIRONMENT=development

# --- JWT Authentication ---
# IMPORTANT: Change SECRET_KEY to a random 32+ character string in production!
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Google OAuth (optional — leave empty to disable) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# --- Service Ports ---
BACKEND_PORT=8001
FRONTEND_PORT=3001

# --- Frontend ---
VITE_API_URL=http://localhost:8001

# --- CORS ---
CORS_ORIGINS=http://localhost:3001,http://localhost:5173
